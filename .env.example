# Public browser configuration (safe to expose in a Next.js client bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy browser key fallback for older Supabase projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only configuration. Never prefix secret credentials with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# Optional legacy server fallback for older Supabase projects.
SUPABASE_SERVICE_ROLE_KEY=
SENTRY_DSN=
